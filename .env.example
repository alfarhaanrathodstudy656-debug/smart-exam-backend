NODE_ENV=development
PORT=5000
TRUST_PROXY=false
MONGO_URI=mongodb://127.0.0.1:27017/smart_exam_system
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
DEFAULT_NEGATIVE_MARK_RATIO=0.25
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,https://smart-exam-system-umber.vercel.app

GOOGLE_CLIENT_ID=
GOOGLE_ADMIN_ALLOWLIST=alfarhaanrathodstudy656@gmail.com
PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
ADMIN_PORTAL_ACCESS_KEY=change_this_admin_security_key

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Smart Exam <no-reply@smart-exam.local>

OPENAI_API_KEY=
